# Postgres connection string, e.g. postgresql://user:password@localhost/bitsocial_github_alerts
DATABASE_URL=
# Public base URL where GitHub can reach this server
WEBHOOK_BASE_URL=https://github.bitsocial.net
# HTTP port the server listens on (default 8080)
PORT=8080
# Telegram bot token from @BotFather (required)
GITHUB_TELOXIDE_TOKEN=
# Admin logging to a Telegram chat: ACTIVE or NOT_ACTIVE
ADMIN_LOGS=NOT_ACTIVE
# 0-255, higher = more verbose admin logs
ADMIN_LOG_LEVEL=50
# Telegram chat id that receives admin logs
TELEGRAM_ADMIN_CHAT_ID=
